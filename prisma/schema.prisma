// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
  MANAGER
}

enum Language {
  en
  es
  fr
}

enum AudienceType {
  CHILDREN
  ADULTS
  STUDENTS
  PROFESSORS
}

enum SubscriptionType {
  TOUR
  DIRECT
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PlanType {
  SINGLE
  MULTI
  UNLIMITED
}

enum BillingCycle {
  WEEKLY
  ONE_MONTH
  THREE_MONTHS
  YEARLY
}

enum PublishStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum FeatureLifecycle {
  PLANNED
  BETA
  ACTIVE
  DEPRECATED
  HIDDEN
  REMOVED
}

enum TourAccessStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum OtpPurpose {
  SIGN_IN
}

enum AuditActionType {
  CREATE
  UPDATE
  DELETE
  PUBLISH
  ARCHIVE
  ROLLBACK
  REVOKE
  LOGIN
  LOGOUT
  PAYMENT
}

enum PurchaseStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum TourAccessSource {
  ADMIN
  SELF_SERVICE
}

enum Platform {
  ios
  android
}

enum TourMediaType {
  IMAGE
  AUDIO
  VIDEO
}

enum TimeOfDay {
  MORNING
  AFTERNOON
  EVENING
}

enum TransitionType {
  STAIRS
  ELEVATOR
  LIFT
  RAMP
  ESCALATOR
}

model User {
  id          String   @id @default(cuid())
  name        String
  age         Int
  email       String   @unique
  countryCode String
  phone       String   @unique
  password    String
  language    Language @default(en)
  role        Role     @default(USER)

  avatarMediaId String?
  avatarMedia   Media?  @relation("UserAvatar", fields: [avatarMediaId], references: [id], onDelete: SetNull)

  subscription Subscription?
  deviceRegistrations DeviceRegistration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id String @id @default(cuid())

  packageName        String
  packageDescription String
  type               SubscriptionType
  status             SubscriptionStatus @default(PENDING)
  startDate          DateTime
  expiryDate         DateTime

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ===== Only for TOUR activation =====
  travellerEmail String?
  ticketNumber   String?
  serialNumber   String?

  // ===== Only for DIRECT payment =====
  paymentId     String?
  transactionId String?
  amount        Float?

  activatedById String?
  activatedAt   DateTime?

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Plan {
  id            String         @id @default(cuid())
  name          String
  description   String?
  type          PlanType
  maxLocations  Int?
  price         Decimal        @db.Decimal(10, 2)
  currency      String         @default("USD")
  billingCycle  BillingCycle
  isActive      Boolean        @default(true)
  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FaqCategory {
  id           String                   @id @default(cuid())
  imageMediaId String?
  imageMedia   Media?                   @relation(fields: [imageMediaId], references: [id], onDelete: SetNull)
  faqs         Faq[]
  translations FaqCategoryTranslation[]
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
}

model FaqCategoryTranslation {
  id         String      @id @default(cuid())
  categoryId String
  category   FaqCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  language   Language
  title      String
  slug       String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([categoryId, language])
  @@unique([language, slug])
}

model Faq {
  id           String           @id @default(cuid())
  categoryId   String
  category     FaqCategory      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  translations FaqTranslation[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model FaqTranslation {
  id          String   @id @default(cuid())
  faqId       String
  faq         Faq      @relation(fields: [faqId], references: [id], onDelete: Cascade)
  language    Language
  question    String
  answer_text String
  answer_html String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([faqId, language])
}

enum KnowledgeCategory {
  KNOWLEDGE
  INFO_PAGE
  LEGAL
}

model KnowledgeArticle {
  id                 String                        @id @default(cuid())
  key                String                        @unique
  category           KnowledgeCategory
  includeInAssistant Boolean                       @default(true)
  lifecycle          FeatureLifecycle              @default(ACTIVE)
  sortOrder          Int                           @default(0)
  icon               String?
  translations       KnowledgeArticleTranslation[]
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt

  @@index([category])
}

model KnowledgeArticleTranslation {
  id        String           @id @default(cuid())
  articleId String
  article   KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  language  Language
  title     String
  bodyHtml  String           @default("")
  bodyText  String           @default("")
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([articleId, language])
}

model Media {
  id           String   @id @default(cuid())
  fileName     String
  originalName String
  url          String
  key          String   @unique
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userAvatars   User[]         @relation("UserAvatar")
  staffProfiles StaffProfile[]
  places        Place[]
  categories    Category[]
  appLanguages  AppLanguage[]
  faqCategories FaqCategory[]
  tours         Tour[]
  spots         Spot[]
  floors        Floor[]
  tourMedia     TourMedia[]
  tourMediaThumbnails TourMedia[] @relation("TourMediaThumbnail")
  appAssets     AppAsset[]
  hosts         Host[]
}

model Tour {
  id                 String        @id @default(cuid())
  slug               String        @unique
  placeId            String?
  place              Place?        @relation(fields: [placeId], references: [id], onDelete: SetNull)
  coverMediaId       String?
  coverMedia         Media?        @relation(fields: [coverMediaId], references: [id], onDelete: SetNull)
  publishStatus      PublishStatus @default(DRAFT)
  tourBundleVersion  Int           @default(1)
  mediaVersion       Int           @default(1)
  aiKnowledgeVersion Int           @default(1)
  routeVersion       Int           @default(1)
  publishedAt        DateTime?
  archivedAt         DateTime?
  translations       TourTranslation[]
  floors             Floor[]
  hosts              Host[]
  spots              Spot[]  // Deprecated: access via floors
  media              TourMedia[]
  aiKnowledge        AiKnowledge[]
  accessGrants       TourAccessTour[]
  bundles            TourBundle[]
  subscriptionPurchases SubscriptionPurchaseTour[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model Floor {
  id              String   @id @default(cuid())
  tourId          String
  tour            Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  floorNo         Int
  sortOrder       Int      @default(0)
  coverMediaId    String?
  coverMedia      Media?   @relation(fields: [coverMediaId], references: [id], onDelete: SetNull)

  translations    FloorTranslation[]
  spots           Spot[]
  route           TourRoute?
  transitionPoints FloorTransitionPoint[]
  connectedFromTransitions FloorTransitionPoint[] @relation("TransitionConnections")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tourId, floorNo])
  @@index([tourId])
}

model FloorTranslation {
  id        String   @id @default(cuid())
  floorId   String
  floor     Floor    @relation(fields: [floorId], references: [id], onDelete: Cascade)
  language  Language
  audience  AudienceType
  name      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([floorId, language, audience])
}

model FloorTransitionPoint {
  id                String        @id @default(cuid())
  floorId           String
  floor             Floor         @relation(fields: [floorId], references: [id], onDelete: Cascade)
  type              TransitionType
  latitude          Decimal       @db.Decimal(10, 7)
  longitude         Decimal       @db.Decimal(10, 7)
  connectsToFloorId String?
  connectsToFloor   Floor?        @relation("TransitionConnections", fields: [connectsToFloorId], references: [id], onDelete: SetNull)
  sortOrder         Int           @default(0)

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([floorId])
  @@index([connectsToFloorId])
}

model Host {
  id            String   @id @default(cuid())
  tourId        String
  tour          Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)

  name          String
  role          String?

  photoMediaId  String?
  photoMedia    Media?   @relation(fields: [photoMediaId], references: [id], onDelete: SetNull)

  latitude      Decimal  @db.Decimal(10, 7)
  longitude     Decimal  @db.Decimal(10, 7)

  availableFrom String?
  availableTo   String?
  isActive      Boolean  @default(true)

  sortOrder     Int      @default(0)

  translations  HostTranslation[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tourId])
}

model HostTranslation {
  id       String   @id @default(cuid())
  hostId   String
  host     Host     @relation(fields: [hostId], references: [id], onDelete: Cascade)

  language Language
  bio      String

  @@unique([hostId, language])
  @@index([hostId])
}

model TourBundle {
  id                 String   @id @default(cuid())
  tourId             String
  tour               Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  bundleId           String   @unique
  tourBundleVersion  Int
  mediaVersion       Int
  aiKnowledgeVersion Int
  routeVersion       Int
  languages          Json
  manifest           Json
  content            Json
  searchDocuments    Json
  checksum           String
  signature          String
  signatureAlgorithm String
  fileCount          Int
  createdAt          DateTime @default(now())

  @@unique([tourId, tourBundleVersion])
  @@index([tourId, createdAt])
}

model TourTranslation {
  id          String       @id @default(cuid())
  tourId      String
  tour        Tour         @relation(fields: [tourId], references: [id], onDelete: Cascade)
  language    Language
  audience    AudienceType @default(ADULTS)
  title       String
  description String       @default("")
  slug        String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([tourId, language, audience])
  @@unique([language, audience, slug])
}

/// A buyer's access grant. Identity is the phone number + a 4-digit PIN the admin
/// sets and passes on by hand (SMS/WhatsApp) — we never hold the buyer's email,
/// so `email` is only present when they came through self-service Stripe checkout.
model TourAccess {
  id                        String           @id @default(cuid())
  phone                     String           @unique
  pinHash                   String
  email                     String?
  /// Access opens on this date and closes on expiresAt; outside that window the tour is locked.
  activatedAt               DateTime         @default(now())
  expiresAt                 DateTime
  status                    TourAccessStatus @default(ACTIVE)
  /// How many devices may hold an active session at once.
  maxDevices                Int              @default(1)
  /// Brute-force guard: a 4-digit PIN is only 10k combinations.
  failedPinAttempts         Int              @default(0)
  pinLockedUntil            DateTime?
  allowSubscriptionFeatures Boolean          @default(false)
  source                    TourAccessSource @default(ADMIN)
  notes                     String?
  activatedById             String?
  tours                     TourAccessTour[]
  deviceSessions            DeviceSession[]
  deviceRegistrations       DeviceRegistration[]
  otpChallenges             OtpChallenge[]
  purchases                 SubscriptionPurchase[]
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt

  @@index([email])
  @@index([status])
}

model TourAccessTour {
  tourAccessId String
  tourId       String
  /// The buyer's planned visit date for this tour. Stored as UTC noon of the
  /// calendar day so a timezone shift can't roll it to the previous/next day.
  /// Seeds the mobile prep-reminder schedule (D-3/D-2/D-1); null = user sets it.
  tourDate     DateTime?
  /// Optional "HH:mm" (24h) start time, used only in reminder copy ("arrive early").
  startTime    String?
  tourAccess   TourAccess @relation(fields: [tourAccessId], references: [id], onDelete: Cascade)
  tour         Tour       @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@id([tourAccessId, tourId])
}

model SubscriptionPlan {
  id             String                 @id @default(cuid())
  name           String
  durationInDays Int
  basePrice      Decimal                @db.Decimal(10, 2)
  isActive       Boolean                @default(true)
  sortOrder      Int                    @default(0)
  purchases      SubscriptionPurchase[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
}

model DevicePricingTier {
  id              String   @id @default(cuid())
  deviceCount     Int      @unique
  additionalPrice Decimal  @db.Decimal(10, 2)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SubscriptionPricingSettings {
  id                         String   @id @default("singleton")
  currency                   String   @default("EUR")
  multiDeviceDiscountEnabled Boolean  @default(true)
  multiDeviceDiscountPercent Decimal  @db.Decimal(5, 2) @default(10)
  maxDevicesPerPurchase      Int      @default(10)
  updatedAt                  DateTime @updatedAt
}

model SubscriptionPurchase {
  id                        String                     @id @default(cuid())
  email                     String
  planId                    String
  plan                      SubscriptionPlan           @relation(fields: [planId], references: [id], onDelete: Restrict)
  deviceCount               Int
  basePriceAtPurchase       Decimal                    @db.Decimal(10, 2)
  deviceSurchargeAtPurchase Decimal                    @db.Decimal(10, 2)
  discountPercentAtPurchase Decimal                    @db.Decimal(5, 2)
  totalAmount               Decimal                    @db.Decimal(10, 2)
  currency                  String
  status                    PurchaseStatus             @default(PENDING)
  stripePaymentIntentId     String?                    @unique
  tourAccessId              String?
  tourAccess                TourAccess?                @relation(fields: [tourAccessId], references: [id], onDelete: SetNull)
  tours                     SubscriptionPurchaseTour[]
  failureReason             String?
  paidAt                    DateTime?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt

  @@index([email])
  @@index([status])
}

model SubscriptionPurchaseTour {
  purchaseId String
  tourId     String
  purchase   SubscriptionPurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  tour       Tour                 @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@id([purchaseId, tourId])
}

model OtpChallenge {
  id           String          @id @default(cuid())
  email        String
  codeHash     String
  purpose      OtpPurpose      @default(SIGN_IN)
  expiresAt    DateTime
  consumedAt   DateTime?
  attemptCount Int             @default(0)
  tourAccessId String?
  tourAccess   TourAccess?     @relation(fields: [tourAccessId], references: [id], onDelete: SetNull)
  createdAt    DateTime        @default(now())

  @@index([email, purpose])
}

model DeviceSession {
  id               String     @id @default(cuid())
  tourAccessId     String
  tourAccess       TourAccess @relation(fields: [tourAccessId], references: [id], onDelete: Cascade)
  deviceId         String
  deviceName       String?
  platform         Platform
  sessionTokenHash String?    @unique
  lastVerifiedAt   DateTime   @default(now())
  revokedAt        DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([tourAccessId, deviceId])
  @@index([deviceId])
}

model DeviceRegistration {
  id           String          @id @default(cuid())
  deviceId     String          @unique
  deviceName   String?
  platform     Platform
  pushToken    String?
  tourAccessId String?
  tourAccess   TourAccess?     @relation(fields: [tourAccessId], references: [id], onDelete: SetNull)
  userId       String?
  user         User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  lastActiveAt DateTime        @default(now())
  revokedAt    DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([tourAccessId])
  @@index([userId])
}

model AuditLog {
  id              String          @id @default(cuid())
  staffAuthUserId String?
  module          String
  actionType      AuditActionType
  entityId        String?
  previousValue   Json?
  newValue          Json?
  ipAddress       String?
  createdAt       DateTime        @default(now())

  @@index([module, createdAt])
  @@index([staffAuthUserId])
}

model StaffProfile {
  id            String   @id @default(cuid())
  authUserId    String   @unique
  avatarMediaId String?
  avatarMedia   Media?   @relation(fields: [avatarMediaId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Place {
  id           String   @id @default(cuid())
  name         String
  imageMediaId String?
  imageMedia   Media?   @relation(fields: [imageMediaId], references: [id], onDelete: SetNull)
  tours        Tour[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category {
  id           String   @id @default(cuid())
  name         String
  imageMediaId String?
  imageMedia   Media?   @relation(fields: [imageMediaId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AppLanguage {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  imageMediaId String?
  imageMedia   Media?   @relation(fields: [imageMediaId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Spot {
  id                  String            @id @default(cuid())
  floorId             String
  floor               Floor             @relation(fields: [floorId], references: [id], onDelete: Cascade)
  tourId              String?           // Deprecated: use floor.tourId instead
  tour                Tour?             @relation(fields: [tourId], references: [id], onDelete: Cascade)
  latitude            Decimal?          @db.Decimal(10, 7)
  longitude           Decimal?          @db.Decimal(10, 7)
  sortOrder           Int               @default(0)
  includedInQuickTour Boolean           @default(true)
  thumbnailMediaId    String?
  thumbnailMedia   Media?            @relation(fields: [thumbnailMediaId], references: [id], onDelete: SetNull)
  translations     SpotTranslation[]
  faqs             SpotFaq[]
  media            TourMedia[]
  aiKnowledge      AiKnowledge[]
  routeEdgesFrom   RouteEdge[]       @relation("RouteEdgeFromSpot")
  routeEdgesTo     RouteEdge[]       @relation("RouteEdgeToSpot")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([floorId, sortOrder])
}

model SpotTranslation {
  id                   String       @id @default(cuid())
  spotId               String
  spot                 Spot         @relation(fields: [spotId], references: [id], onDelete: Cascade)
  language             Language
  audience             AudienceType @default(ADULTS)
  title                String
  shortDesc            String       @default("")
  quillJson            Json         @default("{}")
  descriptionText      String       @default("")
  descriptionHtml      String       @default("")
  interestingFactsText String       @default("")
  interestingFactsHtml String       @default("")
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@unique([spotId, language, audience])
}

model SpotFaq {
  id           String               @id @default(cuid())
  spotId       String
  spot         Spot                 @relation(fields: [spotId], references: [id], onDelete: Cascade)
  sortOrder    Int                  @default(0)
  translations SpotFaqTranslation[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([spotId, sortOrder])
}

model SpotFaqTranslation {
  id          String       @id @default(cuid())
  spotFaqId   String
  spotFaq     SpotFaq      @relation(fields: [spotFaqId], references: [id], onDelete: Cascade)
  language    Language
  audience    AudienceType @default(ADULTS)
  question    String
  answerText  String
  answerHtml  String
  answerJson  Json         @default("{}")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([spotFaqId, language, audience])
}

model TourRoute {
  id        String      @id @default(cuid())
  floorId   String      @unique
  floor     Floor       @relation(fields: [floorId], references: [id], onDelete: Cascade)
  tourId    String?     // Deprecated: use floor.tourId instead
  edges     RouteEdge[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model RouteEdge {
  id             String    @id @default(cuid())
  routeId        String
  route          TourRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  fromSpotId     String
  fromSpot       Spot      @relation("RouteEdgeFromSpot", fields: [fromSpotId], references: [id], onDelete: Cascade)
  toSpotId       String
  toSpot         Spot      @relation("RouteEdgeToSpot", fields: [toSpotId], references: [id], onDelete: Cascade)
  sortOrder      Int       @default(0)
  footprintGeo   Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([routeId, sortOrder])
}

model TourMedia {
  id                  String         @id @default(cuid())
  tourId              String
  tour                Tour           @relation(fields: [tourId], references: [id], onDelete: Cascade)
  spotId              String?
  spot                Spot?          @relation(fields: [spotId], references: [id], onDelete: SetNull)
  mediaId             String
  media               Media          @relation(fields: [mediaId], references: [id], onDelete: Restrict)
  thumbnailMediaId    String?
  thumbnailMedia      Media?         @relation("TourMediaThumbnail", fields: [thumbnailMediaId], references: [id], onDelete: SetNull)
  type                TourMediaType
  language            Language       @default(en)
  audience            AudienceType   @default(ADULTS)
  includedInQuickTour Boolean        @default(true)
  sortOrder           Int            @default(0)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([tourId, type])
  @@index([spotId])
}

model AiKnowledge {
  id           String                   @id @default(cuid())
  tourId       String
  tour         Tour                     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  spotId       String?
  spot         Spot?                    @relation(fields: [spotId], references: [id], onDelete: SetNull)
  sortOrder    Int                      @default(0)
  translations AiKnowledgeTranslation[]
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@index([tourId, sortOrder])
  @@index([spotId])
}

model AiKnowledgeTranslation {
  id          String       @id @default(cuid())
  knowledgeId String
  knowledge   AiKnowledge  @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
  language    Language
  audience    AudienceType @default(ADULTS)
  title       String       @default("")
  content     String
  keywords    String       @default("")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([knowledgeId, language, audience])
}

model AppUiString {
  id           String                   @id @default(cuid())
  key          String                   @unique
  lifecycle    FeatureLifecycle         @default(ACTIVE)
  translations AppUiStringTranslation[]
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
}

model AppUiStringTranslation {
  id       String      @id @default(cuid())
  stringId String
  string   AppUiString @relation(fields: [stringId], references: [id], onDelete: Cascade)
  language Language
  value    String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([stringId, language])
}

model AppAsset {
  id        String           @id @default(cuid())
  key       String           @unique
  mediaId   String
  media     Media            @relation(fields: [mediaId], references: [id], onDelete: Restrict)
  timeOfDay TimeOfDay?
  lifecycle FeatureLifecycle @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model AppReleaseConfig {
  id                    String        @id @default("singleton")
  appContentVersion     Int           @default(1)
  knowledgeVersion      Int           @default(1)
  apiVersion            Int           @default(1)
  schemaVersion         Int           @default(1)
  remoteConfigVersion   Int           @default(1)
  publishStatus         PublishStatus @default(DRAFT)
  publishedAt           DateTime?
  maintenanceMode       Boolean       @default(false)
  maintenanceMessage    String?
  enableOfflineChat     Boolean       @default(true)
  enableGpsNavigation   Boolean       @default(false)
  enableVoiceGuidance   Boolean       @default(true)
  maxDownloadSizeMb       Int           @default(500)
  maxChatHistory          Int           @default(50)
  supportedLanguages      Json          @default("[\"en\",\"es\",\"fr\"]")
  emergencyAnnouncement String?
  // Tour-reminder cadence (admin-controlled). Days-before-visit each prep
  // reminder fires, the local hour it fires at, and whether the undated daily
  // "set a date" nudge runs.
  reminderOffsetDays      Json          @default("[3,2,1]")
  reminderHour            Int           @default(9)
  reminderNudgeEnabled    Boolean       @default(true)
  // The venue's wall-clock timezone (IANA). Host opening hours are bare "HH:mm"
  // and mean nothing without it; the server runs in UTC and a visitor's device
  // carries a foreign zone, so neither can supply it. The default here is a data
  // default (admin-editable), not a business rule.
  venueTimezone           String        @default("Europe/Rome")
  updatedAt             DateTime      @updatedAt
}
