DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/aurelia?schema=public"
NEXT_PUBLIC_API_BASE_URL="http://localhost:3000/api/v1"

# Neon Auth (https://neon.com/docs/auth/overview)
NEON_AUTH_BASE_URL="https://ep-xxx.neonauth.us-east-1.aws.neon.tech/neondb/auth"
NEON_AUTH_COOKIE_SECRET="generate-with-openssl-rand-base64-32"

# Cloudflare R2 (https://developers.cloudflare.com/r2/)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_BUCKET_URL=""

# Tour bundle signing (RSA preferred; HMAC secret for local/dev)
# BUNDLE_SIGNING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
BUNDLE_SIGNING_SECRET=""

# Mobile public API (/api/v1/app/*)
# Must match EXPO_PUBLIC_MOBILE_API_KEY in aurelia-app exactly.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Do NOT ship a value that appears in this file — it is public.
MOBILE_API_KEY=""
# Required in production — the app throws rather than falling back to a pepper
# committed in this repo. Changing an already-deployed value invalidates every
# device session (and device removal is admin-only), so rotate deliberately.
MOBILE_SESSION_PEPPER=""
MOBILE_OTP_PEPPER=""

# Escape hatch for local work when MOBILE_API_KEY is unset. Set to "1" to skip
# the mobile API-key check. Never set this on a deployed environment.
ALLOW_INSECURE_MOBILE_API=""

# Mobile OTP email (Resend — https://resend.com)
RESEND_API_KEY=""
OTP_EMAIL_FROM="Aurelia <onboarding@resend.dev>"

# Optional OSRM base URL for admin route footprint generation
# OSRM_BASE_URL="https://router.project-osrm.org"

# Stripe (self-service mobile subscriptions — https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

